<% @query.inline_columns.each do |column| %>
  <td class="<%= column.css_classes %>">
    <% case column.name.to_s %>
    <% when 'type' %>
      <% type_label = case key.type
                     when 'Vault::Password' then t('activerecord.models.password')
                     when 'Vault::Sftp' then t('activerecord.models.sftp')
                     when 'Vault::KeyFile' then t('activerecord.models.key_file')
                     else key.type.demodulize
                     end %>
      <% if key.project.nil? %>
        <span style="color: #999; text-decoration: line-through;"><%= type_label %></span>
      <% else %>
        <label id="type_<%= key.id %>" class='keys-links'><%= type_label %></label>
      <% end %>
    <% when 'name' %>
      <% if key.project.nil? %>
        <span style="color: #999; text-decoration: line-through;"><%= key.name %></span>
      <% else %>
        <%= link_to key.name, edit_project_key_path(key.project, key), class: 'keys-links' %>
      <% end %>
    <% when 'url' %>
      <% unless key.url.blank? %>
        <span class='url-wrapper'>
          <a class='keys-actions copy-key' data-clipboard-target='copy_url_<%= key.id %>' title='<%= t('key.btn.clipboard') %>'>
            <i class="fa fa-clipboard fa-fw"></i>
          </a>
          <% if /:\/\//.match(key.url) %>
            <%= link_to key.url, key.url, class: 'keys-links' %>
          <% else %>
            <label class='keys-links'><%= key.url %></label>
          <% end %>
          <input style="position: absolute; left: -9999px; top: -9999px;" type="text" id="copy_url_<%= key.id %>" value="<%= key.url %>" readonly />
        </span>
      <% end %>
    <% when 'login' %>
      <% unless key.login.blank? %>
        <span class='login-wrapper'>
          <a class='keys-actions copy-key' data-clipboard-target='copy_login_<%= key.id %>' title='<%= t('key.btn.clipboard') %>'>
            <i class="fa fa-clipboard fa-fw"></i>
          </a>
          <label class='keys-links'><%= key.login %></label>
          <input style="position: absolute; left: -9999px; top: -9999px;" type="text" id="copy_login_<%= key.id %>" value="<%= key.login %>" readonly />
        </span>
      <% end %>
    <% when 'body' %>
      <% if (key.type == 'Vault::Sftp' || key.type == 'Vault::KeyFile') && key.file.present? && key.project.present? %>
        <%= link_to "/projects/#{key.project.identifier}/keys/#{key.id}/download", class: 'keys-actions', title: 'Download file', id: "keyfile_dl_#{key.id}" do %>
          <i class='fa fa-download fa-fw'></i>
        <% end %>
      <% end %>
      <% unless key.body.blank? %>
        <a class='keys-actions copy-key' data-clipboard-target='copy_body_<%= key.id %>' title='<%= t('key.btn.clipboard') %>'>
          <i class="fa fa-clipboard fa-fw"></i>
        </a>
        <span>&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;</span>
        <input style="position: absolute; left: -9999px; top: -9999px;" type="text" id="copy_body_<%= key.id %>" value="<%= key.body ? key.body.force_encoding('UTF-8') : '' %>" readonly />
      <% end %>
    <% else %>
      <%= column_content(column, key) %>
    <% end %>
  </td>
<% end %>


