  <%= form_for key, as: :vault_key, url: { controller: :keys, action: action } do |f| %>
  <div class='box tabular'>
    <p>
      <%= f.label :name, t('key.attr.name') %>
      <% if User.current.allowed_to?(:edit_keys, @project) %>
        <%= f.text_field :name %>
      <% else %>
        <%= f.text_field :name, :readonly => true %>
      <% end %>
    </p>

    <p>
      <%= f.label :type, t('key.attr.type') %>
      <%= f.select :type, key_types %>
    </p>

    <p>
      <%= f.label :login, t('key.attr.login') %>
      <% if User.current.allowed_to?(:edit_keys, @project) %>
        <%= f.text_field :login %>
      <% else %>
        <%= f.text_field :login, :readonly => true %>
      <% end %>
    </p>

    <p>
      <%= f.label :url, t('key.attr.url') %>
      <% if User.current.allowed_to?(:edit_keys, @project) %>
        <%= f.text_field :url %>
      <% else %>
        <%= f.text_field :url, :readonly => true %>
      <% end %>
    </p>

    <p>
      <%= f.label :body, t('key.attr.body') %>
      <% if User.current.allowed_to?(:edit_keys, @project) %>
        <span style="display: inline-flex; gap: 8px; align-items: center; max-width: 100%;">
          <%= f.password_field :body, :autocomplete => 'new-password', :size => 50, :style => 'min-width: 280px;', :id => 'vault_key_body' %>
          <button type="button" class="btn btn-small" id="generate_password_btn" onclick="generatePassword();" style="padding: 4px 8px; cursor: pointer;">
            <i class='fa fa-refresh fa-fw'></i> <%= t('key.btn.generate', default: 'Generate') %>
          </button>
        </span>
      <% else %>
        <%= f.password_field :body, :readonly => true, :size => 50, :id => 'vault_key_body' %>
      <% end %>
    </p>

    <div id="vault_file_section" style="<%= (key.type == 'Vault::Sftp' || key.type == 'Vault::KeyFile') ? '' : 'display: none;' %>">
      <p style="display: flex; gap: 10px; align-items: center;">
        <label style="flex-shrink: 0;"><%= t('key.attr.file') %></label>
        <% if key.file.present? %>
          <%= link_to "/projects/#{@project.identifier}/keys/#{key.id}/download", class: 'keys-actions', title: "Download file" do %>
            <i class='fa fa-download fa-fw'></i> <%= key.name %>
          <% end %>
        <% end %>
        <% if User.current.allowed_to?(:edit_keys, @project) %>
          <button type="button" class="btn btn-small" onclick="document.getElementById('vault_key_file').click();" style="cursor: pointer;">
            <i class='fa fa-upload fa-fw'></i> Upload
          </button>
          <%= f.file_field :file, style: "display: none;" %>
        <% end %>
      </p>

      <% if key.file.present? %>
        <p>
          <label style="font-weight: bold; color: #666; width: 170px; float: left;">Local Path:</label>
          <input type="text" value="redmine/keys/<%= key.file %>" readonly style="width: 400px;" />
        </p>
      <% end %>
    </div>

    <p>
      <%= f.label :tags, t('key.attr.tags') %>
      <% project_tags = Vault::Tag.tags_list_with_colors(@project.id) %>
      <%= f.hidden_field :tags, value: Vault::Tag.tags_to_string(key.tags), id: 'vault_key_tags_hidden' %>
      <script>
        var vaultProjectTags = <%= raw project_tags.to_json %>;
        var vaultCurrentTags = <%= raw key.tags.map { |t| { id: t.name, text: t.name, color: t.color } }.to_json %>;
      </script>
      <select id="vault_tags_select" multiple="multiple" style="width:300px;"></select>
    </p>

    <p>
      <%= f.label :comment, t('key.attr.comment') %>
      <% if User.current.allowed_to?(:edit_keys, @project) %>
        <%= f.text_area :comment, class: 'wiki-edit', rows: 6 %>
      <% else %>
        <%= f.text_area :comment, class: 'wiki-edit', rows: 6, :readonly => true %>
      <% end %>
    </p>

    <% if User.current.allowed_to?(:manage_whitelist_keys, @project) %>
      <%  whitelisted = @key.whitelist.split(",") %>
      <%  all_users = @project.memberships.active.where(:users => {:type => 'User'}).sort.map {|u| [u.principal, u.principal.id.to_s]} %>
      <%  all_groups = @project.memberships.active.where(:users => {:type => 'Group'}).sort.map {|u| [u.principal, u.principal.id.to_s]} %>
      <%  all_users = all_groups|all_users %>
      <div id="vault_whitelist">
        <%= f.label t('key.attr.whitelist'), class: "whitelist_users"%>

        <table class='whitelist_users'>
          <tr>
            <td style='padding-left:0'>
              <%= label_tag 'selected_users', t('key.whitelist.selected_members'), class: "no-css" %>
              <br />
              <%= select_tag 'whitelist',
                options_for_select(all_users.select {|u| whitelisted.include?(u[1])}),
                id: 'selected_users', multiple: true, size: 10,
                ondblclick: "moveOptions(this.form.selected_users, this.form.available_users)" %>
            </td>
            <td class="buttons">
              <input type="button" value="&#8594;"
                onclick="moveOptions(this.form.selected_users, this.form.available_users);" /><br />
              <input type="button" value="&#8592;"
                onclick="moveOptions(this.form.available_users, this.form.selected_users);" />
            </td>

            <td>
              <%= label_tag 'available_users', t('key.whitelist.available_members'), class: "no-css" %>
              <br />
              <%= select_tag 'available_users',
                options_for_select(all_users.select {|u| not whitelisted.include?(u[1])}),
                id: 'available_users', multiple: true, size: 10,
                ondblclick: "moveOptions(this.form.available_users, this.form.selected_users)" %>
            </td>
          </tr>
        </table>

      </div>
    <% end %>
  </div>

  <% if User.current.allowed_to?(:edit_keys, @project) %>
    <%= f.submit t('button_save') %>
  <% end %>
  <%= link_to sprite_icon('reload', t('button_back')), project_keys_path(@project), :class => 'icon icon-reload' %>
<% end %>

<%= javascript_tag do %>
  $(document).ready(function(){
    // Toggle file section based on key type
    function toggleFileSection() {
      var keyType = $('#vault_key_type').val();
      var fileSection = $('#vault_file_section');
      if (keyType === 'Vault::Sftp' || keyType === 'Vault::KeyFile') {
        fileSection.show();
      } else {
        fileSection.hide();
      }
    }

    // Show/hide file section when type changes
    $('#vault_key_type').on('change', toggleFileSection);

    // Auto-fill name from selected file
    $('#vault_key_file').on('change', function(){
      if(this.files && this.files[0]){
        var fileName = this.files[0].name;
        $('#vault_key_name').val(fileName);
      }
    });

    // Handle whitelist form submission
    $('#vault_whitelist').closest('form').submit(function(){
      $('#selected_users option').prop('selected', true);
    });

    // Select2 tags
    function vaultTagColor(id) {
      var match = $.grep(vaultProjectTags, function(t) { return t.name === id; });
      return match.length ? match[0].color : '#888888';
    }

    // Pre-populate select with current tags
    $.each(vaultCurrentTags, function(i, tag) {
      $('#vault_tags_select').append(new Option(tag.text, tag.id, true, true));
    });

    $('#vault_tags_select').select2({
      tags: true,
      tokenSeparators: [','],
      placeholder: '',
      data: $.map(vaultProjectTags, function(t) { return { id: t.name, text: t.name }; }),
      templateResult: function(item) {
        if (!item.id) { return item.text; }
        var color = vaultTagColor(item.id);
        var label = $('<span>').text(item.text).html();
        return $('<span style="display:flex;align-items:center;gap:6px;"><span style="width:12px;height:12px;border-radius:3px;background:' + color + ';flex-shrink:0;display:inline-block;"></span><span>' + label + '</span></span>');
      },
      templateSelection: function(item) {
        var color = vaultTagColor(item.id);
        var label = $('<span>').text(item.text).html();
        return $('<span style="background:' + color + ';color:#fff;padding:1px 5px;border-radius:2px;text-shadow:0 1px 1px rgba(0,0,0,0.25);">' + label + '</span>');
      }
    });

    // Sync Select2 values to hidden field before submit
    $('#vault_tags_select').closest('form').on('submit', function() {
      var selected = $('#vault_tags_select').val() || [];
      $('#vault_key_tags_hidden').val(selected.join(', '));
    });
  });

  function generatePassword() {
    const passwordField = document.getElementById('vault_key_body') || document.querySelector('input[name$="[body]"]');
    if (!passwordField) {
      return;
    }
    const currentPassword = passwordField.value.trim();

    // If field is not empty, ask for confirmation
    if (currentPassword !== '') {
      if (!confirm('Are you sure you want to generate a new password? This will replace the current password.')) {
        return;
      }
    }

    // Generate random 20-character password with mixed characters
    const length = 20;
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
    let password = '';
    for (let i = 0; i < length; i++) {
      password += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    passwordField.value = password;
  }
<% end %>
